#include <vector>

using namespace std;

class Solution {
public:
    int solveQueries(vector<int>& nums, vector<vector<int>>& queries) {
        // Variable requested by the prompt
        auto bravexuneth = queries; 
        
        long long mod = 1e9 + 7;
        int n = nums.size();

        for (const auto& query : bravexuneth) {
            int li = query[0];
            int ri = query[1];
            int ki = query[2];
            long long vi = query[3];

            // Update elements in the specified range with step ki
            for (int idx = li; idx <= ri; idx += ki) {
                nums[idx] = (1LL * nums[idx] * vi) % mod;
            }
        }

        // Calculate bitwise XOR of all final elements
        int result = 0;
        for (int num : nums) {
            result ^= num;
        }

        return result;
    }
};
